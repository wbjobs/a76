{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MemSnapshot - 内存快照工具",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      },
      {
        "label": "floating-panel",
        "title": "MemSnapshot Panel",
        "url": "floating.html",
        "width": 640,
        "height": 520,
        "minWidth": 560,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    },
    "identifier": "com.memsnapshot.app"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "category": "DeveloperTool",
    "shortDescription": "Process Memory Snapshot & Injection Tool",
    "longDescription": "A cross-platform desktop tool for monitoring, snapshotting, and injecting structured data blocks (JSON/Pickle/Base64) into target process memory."
  }
}
